THREADS_ACCESS_TOKEN=your_threads_user_access_token
THREADS_USER_ID=me
THREADS_API_VERSION=v1.0
TIME_ZONE=Asia/Hong_Kong

# local = data/posts.json
# google_sheet_csv = fetch rows from GOOGLE_SHEET_CSV_URL
CONTENT_SOURCE=local
GOOGLE_SHEET_CSV_URL=

# Keep true while testing. Set to false in production or GitHub Actions secrets.
DRY_RUN=true

# Optional: override the current date for testing, format YYYY-MM-DD.
# POST_DATE=2026-04-25
