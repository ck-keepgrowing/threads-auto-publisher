THREADS_ACCESS_TOKEN=your_threads_user_access_token
THREADS_USER_ID=me
THREADS_API_VERSION=v1.0
TIME_ZONE=Asia/Hong_Kong

# Used only when getting your access token.
THREADS_APP_ID=your_threads_app_id
THREADS_APP_SECRET=your_threads_app_secret
THREADS_REDIRECT_URI=https://ck-keepgrowing.github.io/threads-auto-publisher/callback/

# Telegram approval bot settings.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Used when the editor needs to generate or revise posts.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# local = data/posts.json
# google_sheet_csv = fetch rows from GOOGLE_SHEET_CSV_URL
CONTENT_SOURCE=local
GOOGLE_SHEET_CSV_URL=

# Keep true while testing. Set to false in production or GitHub Actions secrets.
DRY_RUN=true

# Optional: override the current date for testing, format YYYY-MM-DD.
# POST_DATE=2026-04-25
